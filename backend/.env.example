# ══════════════════════════════════════════════════════════════════
#  Math Copilot - Environment Variables
# ══════════════════════════════════════════════════════════════════
#  复制本文件为 .env，然后按需填入真实值。
#  后端通过 pydantic-settings (backend/config.py) 自动加载。
#  ⚠️  请勿将真实 .env 提交到版本控制。
# ══════════════════════════════════════════════════════════════════


# ── LLM 全局配置（所有角色未单独配置时的 fallback）──────────
#  Provider: openai | anthropic | mock
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4-turbo-preview

#  OpenAI 兼容服务（也用于任何 base_url 指向 OpenAI 协议的服务）
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1

#  Anthropic Claude（仅当 LLM_PROVIDER=anthropic 时使用）
ANTHROPIC_API_KEY=


# ── 应用 ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true


# ── 沙箱 ─────────────────────────────────────────────────────
SANDBOX_TIMEOUT=30
#  sandbox 模式: subprocess | docker
SANDBOX_MODE=subprocess


# ── 路径 ─────────────────────────────────────────────────────
#  Skills 目录（相对路径将基于 backend/config.py 自动解析为绝对路径）
SKILLS_DIR=./skills
