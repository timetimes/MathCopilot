# ══════════════════════════════════════════════════════════════════
#  Math Copilot - Environment Variables
# ══════════════════════════════════════════════════════════════════
#  复制本文件为 .env，然后按需填入真实值。
#  后端通过 pydantic-settings (backend/config.py) 自动加载。
#  ⚠️  请勿将真实 .env 提交到版本控制。
# ══════════════════════════════════════════════════════════════════


# ── LLM 全局配置（所有角色未单独配置时的 fallback）──────────
#  Provider: openai | anthropic | mock
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4-turbo-preview

#  OpenAI 兼容服务（也用于任何 base_url 指向 OpenAI 协议的服务）
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

#  Anthropic Claude（仅当 LLM_PROVIDER=anthropic 时使用）
# ANTHROPIC_API_KEY=


# ── 角色级模型配置（可选，留空则使用全局配置）───────────
# 命名规则：{ROLE}_PROVIDER / {ROLE}_MODEL_NAME / {ROLE}_API_KEY / {ROLE}_BASE_URL
# 支持的角色: INPUT, SOLUTION, ROUTER, VIZ_CODE
# 每个角色都可以指定不同的 provider / model / key / url
# 全部留空时，所有角色使用上面的全局配置

# 输入清洗模型（轻量模型推荐，如 deepseek-chat / gpt-4o-mini）
INPUT_PROVIDER=
INPUT_MODEL_NAME=
INPUT_API_KEY=
INPUT_BASE_URL=

# 解题模型（强模型，如 gpt-4o / claude-sonnet-4-20250514）
SOLUTION_PROVIDER=
SOLUTION_MODEL_NAME=
SOLUTION_API_KEY=
SOLUTION_BASE_URL=

# Skill 路由模型（轻量模型。未配置时使用关键词匹配，不调用 LLM）
ROUTER_PROVIDER=
ROUTER_MODEL_NAME=
ROUTER_API_KEY=
ROUTER_BASE_URL=

# 可视化代码生成模型
VIZ_CODE_PROVIDER=
VIZ_CODE_MODEL_NAME=
VIZ_CODE_API_KEY=
VIZ_CODE_BASE_URL=


# ── 应用 ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true


# ── 沙箱 ─────────────────────────────────────────────────────
SANDBOX_TIMEOUT=30
#  sandbox 模式: subprocess | docker
SANDBOX_MODE=subprocess


# ── 路径 ─────────────────────────────────────────────────────
#  Skills 目录（相对路径将基于 backend/config.py 自动解析为绝对路径）
SKILLS_DIR=./skills
